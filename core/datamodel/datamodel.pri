# datamodel

#将当前目录加入到头文件路径
INCLUDEPATH += $$PWD

SOURCES += \
  $$PWD/commands.cpp \
  $$PWD/distancelistmodel.cpp \
  $$PWD/modelmanager.cpp \
  $$PWD/pointslistmodel.cpp \
  $$PWD/trajectorylistmodel.cpp \


HEADERS += \
  $$PWD/commands.h \
  $$PWD/distancelistmodel.h \
  $$PWD/modelmanager.h \
  $$PWD/pointslistmodel.h \
  $$PWD/trajectorylistmodel.h \
