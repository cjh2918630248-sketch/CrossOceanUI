Language: Proto # 指定语言为 Protocol Buffers
IndentWidth: 2 # 缩进宽度为 2 个空格
AlignConsecutiveAssignments: true # 对齐连续的赋值语句
AlignConsecutiveDeclarations: true # 对齐连续的声明
AlignTrailingComments: true # 对齐尾随注释
AllowShortFunctionsOnASingleLine: None # 不允许短函数放在单行
AllowShortIfStatementsOnASingleLine: false # 不允许短 if 语句放在单行
AllowShortLoopsOnASingleLine: false # 不允许短循环放在单行
BreakBeforeBraces: Allman # 大括号换行风格（Allman 风格）
ColumnLimit: 80 # 每行最多 80 个字符
IndentCaseLabels: true # 缩进 case 标签
KeepEmptyLinesAtTheStartOfBlocks: true # 保留块开始处的空行
MaxEmptyLinesToKeep: 1 # 最多保留 1 个连续空行
PointerAlignment: Left # 指针对齐方式（左对齐）
SortIncludes: true # 自动排序 include 语句
SpaceBeforeParens: ControlStatements # 控制语句的括号前加空格
SpacesInParentheses: false # 括号内不加空格
